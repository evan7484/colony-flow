rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 닉네임 기반 랭킹: 누구나 읽기 가능
    // 쓰기: 형식 검증 + 레벨 단조 증가 + PIN 해시 일치(소유권)
    // PIN 도입 이전 문서(pinHash 없음)는 첫 로그인이 같은 레벨로 클레임 가능
    match /players/{nick} {
      allow read: if true;
      allow create: if validPlayer(nick);
      allow update: if validPlayer(nick)
        && (!('pinHash' in resource.data)
            || request.resource.data.pinHash == resource.data.pinHash)
        && (request.resource.data.bestLevel > resource.data.bestLevel
            || (request.resource.data.bestLevel == resource.data.bestLevel
                && !('pinHash' in resource.data)));
      allow delete: if false;

      function validPlayer(nick) {
        let d = request.resource.data;
        return d.keys().hasOnly(['nickname', 'bestLevel', 'updatedAt', 'pinHash'])
          && d.nickname is string
          && d.nickname == nick
          && nick.size() >= 2 && nick.size() <= 36
          && d.bestLevel is int
          && d.bestLevel >= 0 && d.bestLevel <= 30
          && d.updatedAt is int
          && d.pinHash is string
          && d.pinHash.size() >= 4 && d.pinHash.size() <= 64;
      }
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
